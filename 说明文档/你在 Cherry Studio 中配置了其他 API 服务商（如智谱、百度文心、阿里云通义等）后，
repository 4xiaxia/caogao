##### 2. 代码示例（Python，调用 Agent 绑定的工具）
```python
import openai
import json

client = openai.OpenAI(
    api_key="cherry_sk_xxxx",
    base_url="http://192.168.1.100:8000/v1"
)

def chat_with_tool(user_input):
    # 定义要调用的 Cherry 工具（需与 Agent 配置的工具名称一致）
    tools = [
        {
            "type": "function",
            "function": {
                "name": "db_query_tool",  # Cherry 控制台配置的工具名称
                "description": "查询业务数据库中的订单数据",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "order_id": {
                            "type": "string",
                            "description": "订单ID"
                        }
                    },
                    "required": ["order_id"]
                }
            }
        }
    ]

    # 调用接口（自动触发 Agent 绑定的工具）
    response = client.chat.completions.create(
        model="cherry:llama3-8b",  # 指定 Cherry 模型
        messages=[
            {"role": "user", "content": user_input}
        ],
        tools=tools,  # 传入工具列表
        tool_choice="auto",  # 自动选择工具（也可指定具体工具名）
        temperature=0.7
    )

    # 解析工具调用结果
    tool_calls = response.choices[0].message.tool_calls
    if tool_calls:
        for tool_call in tool_calls:
            # 获取工具调用参数
            args = json.loads(tool_call.function.arguments)
            print(f"调用工具 {tool_call.function.name}，参数：{args}")
            # 原有系统可在此处对接本地工具执行逻辑
            return f"工具调用结果：订单 {args['order_id']} 金额为 100 元"
    else:
        return response.choices[0].message.content

# 调用测试（触发工具）
print(chat_with_tool("查询订单ID为OD123456的金额"))
```

##### 3. 工具调用流程说明
1. 原有系统发送包含 `tools` 参数的请求 → Cherry Studio 接收后，通过 Agent 匹配对应的工具；
2. Cherry 调用本地工具执行（如数据库查询）→ 返回工具执行结果；
3. Cherry 将工具结果整理为对话格式，返回给原有系统；
4. 原有系统解析 `tool_calls` 字段，可直接使用结果，或继续调用其他工具。

