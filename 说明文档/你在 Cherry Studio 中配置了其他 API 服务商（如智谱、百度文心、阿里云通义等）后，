    {
      "index": 0,
      "message": {
        "role": "assistant",
        "content": "OAS 3.0（OpenAPI Specification 3.0）是一种用于描述RESTful API的规范..."
      },
      "finish_reason": "stop"
    }
  ],
  "usage": {
    "prompt_tokens": 20,
    "completion_tokens": 150,
    "total_tokens": 170
  }
}
```

